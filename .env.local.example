# Supabase Configuration
# Copy this file to .env.local and fill in the values below from your Supabase dashboard settings.
# If these variables are not defined, the application will fallback to a fully operational local storage mock database.

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
