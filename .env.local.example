# Supabase Configuration
# Copy this file to .env.local and fill in the values.
# If NEXT_PUBLIC_SUPABASE_URL and NEXT_PUBLIC_SUPABASE_ANON_KEY are not defined, the application will fallback to a fully operational local storage mock database.

NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Admin Portal Configuration
ADMIN_PASSCODE=your_custom_admin_passcode
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com
ADMIN_EMAIL=admin@example.com

# AI Passage Generation (Optional - used by the daily auto-scheduler cron)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
